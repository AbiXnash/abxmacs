;; Package management
(require 'package)
(add-to-list 'package-archives '("elpa" . "https://elpa.gnu.org/packages/") t)
(add-to-list 'package-archives '("melpa" . "https://melpa.org/packages/") t)
(package-initialize)
(when (not (package-installed-p 'org))
  (package-refresh-contents)
  (package-install 'org))

;; remove the startup message
(setq inhibit-startup-message t)

;; need to add comments 
(setq transient-mark-mode t)

;; remove clustered UI (only in graphical mode)
(when (fboundp 'scroll-bar-mode) (scroll-bar-mode -1))
(when (fboundp 'tool-bar-mode) (tool-bar-mode -1))
(when (fboundp 'tooltip-mode) (tooltip-mode -1))
(when (fboundp 'menu-bar-mode) (menu-bar-mode -1))

;; relative line numbers
(display-line-numbers-mode 1)
(setq display-line-numbers-type 'relative)

;; transparent background
(add-to-list 'default-frame-alist '(alpha . 85))

(when (fboundp 'set-fringe-mode) (set-fringe-mode 10))

;; Font configuration (Nerd Font)

;; Gruvbox theme
(unless (package-installed-p 'gruvbox-theme)
  (package-refresh-contents)
  (package-install 'gruvbox-theme))
(setq gruvbox-theme-contrast 'medium)
(load-theme 'gruvbox-dark-soft t)
(set-face-attribute 'default nil :background "unspecified-bg")
(set-face-attribute 'default nil :foreground "unspecified-fg")
(set-frame-parameter nil 'background-color "unspecified-bg")
(custom-set-variables
 ;; custom-set-variables was added by Custom.
